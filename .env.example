# Copy this file to .env and fill in your values.
# This file holds NON-SECRET config only (region, resource names, model ids).
# Never put real keys here. The Qdrant API key lives in SSM Parameter Store
# (SecureString) and is fetched at runtime via ssm:GetParameter - see app/config.py.

AWS_REGION=us-east-1
S3_BUCKET=rag-demo-docs

# Qdrant Cloud cluster URL (NOT the API key). Create a free 1 GB cluster at
# cloud.qdrant.io, then store its API key in SSM under the param name below.
QDRANT_URL=https://<cluster-id>.<region>.aws.cloud.qdrant.io:6333
QDRANT_API_KEY_PARAM=/rag-demo/qdrant-api-key   # SSM param NAME, not the key value
QDRANT_COLLECTION=doc_chunks

# Bedrock model ids (must be enabled in Console -> Bedrock -> Model access first)
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_GEN_MODEL=anthropic.claude-3-haiku-20240307-v1:0
EMBED_DIM=1024

# Observability
CLOUDWATCH_LOG_GROUP=/rag-demo/app

# Demo guardrails
RATE_LIMIT_PER_SESSION=10
TOP_K=5
SIMILARITY_FLOOR=0.35
